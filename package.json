{
  "name": "smartpage",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "dev": "bun run --cwd examples/basic dev",
    "build": "bun run --cwd packages/smartpage build",
    "build:example": "bun run --cwd examples/basic build",
    "build:all": "bun run build && bun run build:example",
    "test": "npx playwright test",
    "test:ui": "npx playwright test --ui",
    "test:headed": "npx playwright test --headed"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2"
  }
}
