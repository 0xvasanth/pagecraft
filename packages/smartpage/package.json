{
  "name": "smartpage",
  "version": "0.5.1",
  "description": "A Google Docs-style WYSIWYG PDF editor built on TipTap. Supports rich text, tables, images (resize/crop), template variables, block plugins (for-loops, conditionals), page breaks, and HTML export for PDF generation.",
  "type": "module",
  "main": "./dist/smartpage.js",
  "module": "./dist/smartpage.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/smartpage.js",
      "default": "./dist/smartpage.js"
    },
    "./styles": "./dist/smartpage.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly",
    "dev": "vite build --watch"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@tiptap/core": "^3.20.4",
    "@tiptap/extension-color": "^3.20.4",
    "@tiptap/extension-dropcursor": "^3.20.4",
    "@tiptap/extension-highlight": "^3.20.4",
    "@tiptap/extension-image": "^3.20.4",
    "@tiptap/extension-link": "^3.20.4",
    "@tiptap/extension-placeholder": "^3.20.4",
    "@tiptap/extension-subscript": "^3.20.4",
    "@tiptap/extension-superscript": "^3.20.4",
    "@tiptap/extension-table": "^3.20.4",
    "@tiptap/extension-table-cell": "^3.20.4",
    "@tiptap/extension-table-header": "^3.20.4",
    "@tiptap/extension-table-row": "^3.20.4",
    "@tiptap/extension-task-item": "^3.20.4",
    "@tiptap/extension-task-list": "^3.20.4",
    "@tiptap/extension-text-align": "^3.20.4",
    "@tiptap/extension-text-style": "^3.20.4",
    "@tiptap/extension-typography": "^3.20.4",
    "@tiptap/extension-underline": "^3.20.4",
    "@tiptap/pm": "^3.20.4",
    "@tiptap/react": "^3.20.4",
    "@tiptap/starter-kit": "^3.20.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "mammoth": "^1.12.0",
    "tailwind-merge": "^3.5.0"
  },
  "optionalDependencies": {
    "pdfjs-dist": "^5.5.207"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "@vitejs/plugin-react": "^6.0.1"
  },
  "keywords": [
    "editor",
    "pdf",
    "wysiwyg",
    "tiptap",
    "rich-text",
    "template",
    "react",
    "document-editor",
    "google-docs"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/0xvasanth/smartpage"
  }
}
